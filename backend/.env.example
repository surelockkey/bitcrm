# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Redis
REDIS_URL=redis://localhost:6379

# Cognito (fill from terraform output)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Service ports
USER_SERVICE_PORT=4001
CRM_SERVICE_PORT=4002
DEAL_SERVICE_PORT=4003
INVENTORY_SERVICE_PORT=4004

# Internal service URLs (for service-to-service calls)
USER_SERVICE_URL=http://localhost:4001
CRM_SERVICE_URL=http://localhost:4002
DEAL_SERVICE_URL=http://localhost:4003
INVENTORY_SERVICE_URL=http://localhost:4004

# LocalStack (SNS, SQS, S3 in local dev — omit in prod to use real AWS)
AWS_ENDPOINT=http://localhost:4566

# S3
S3_BUCKET=bitcrm-uploads

# Internal service secret (for service-to-service HTTP calls)
INTERNAL_SERVICE_SECRET=
