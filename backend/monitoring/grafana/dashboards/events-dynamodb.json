{
  "uid": "bitcrm-events-dynamodb",
  "title": "BitCRM - Events & Messaging",
  "tags": ["bitcrm", "events", "sqs", "sns"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "SNS Event Publish Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bitcrm_events_published_total[5m])) by (event_type)",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "id": 2,
      "title": "Event Publish Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bitcrm_events_failed_total[5m])) by (event_type)",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "SQS Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bitcrm_sqs_messages_processed_total{status=\"success\"}[5m])) by (event_type)",
          "legendFormat": "{{event_type}} (success)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "id": 4,
      "title": "SQS Processing Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bitcrm_sqs_messages_processed_total{status=\"error\"}[5m])) by (event_type)",
          "legendFormat": "{{event_type}} (error)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 5,
      "title": "SQS Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bitcrm_sqs_messages_processed_total{status=\"error\"}[5m])) / sum(rate(bitcrm_sqs_messages_processed_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "SQS Processing Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(bitcrm_sqs_processing_duration_seconds_bucket[5m])) by (le, event_type))",
          "legendFormat": "P95 {{event_type}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(bitcrm_sqs_processing_duration_seconds_bucket[5m])) by (le, event_type))",
          "legendFormat": "P50 {{event_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "title": "Internal HTTP Call Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(bitcrm_internal_http_duration_seconds_bucket[5m])) by (le, target_service, operation))",
          "legendFormat": "{{target_service}} {{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 8,
      "title": "Internal HTTP Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bitcrm_internal_http_errors_total[5m])) by (target_service, operation)",
          "legendFormat": "{{target_service}} {{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "id": 9,
      "title": "Events Published (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(increase(bitcrm_events_published_total[1h]))",
          "legendFormat": "Published"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "title": "Events Failed (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(increase(bitcrm_events_failed_total[1h]))",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "SQS Messages Processed (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(increase(bitcrm_sqs_messages_processed_total[1h]))",
          "legendFormat": "Processed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
