{
  "name": "inventory-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config test/integration/jest-integration.json",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config test/e2e/jest-e2e.json",
    "setup:db": "ts-node src/scripts/setup-dynamodb.ts",
    "setup:aws": "ts-node src/scripts/setup-aws.ts",
    "setup": "npm run setup:db && npm run setup:aws"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sns": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@bitcrm/shared": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@scalar/nestjs-api-reference": "^0.3.0",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.14.4",
    "csv-parse": "^5.6.0",
    "dotenv": "~17.3.1",
    "nestjs-pino": "~4.6.1",
    "prom-client": "^15.1.0",
    "pino": "~10.3.1",
    "pino-http": "~11.0.0",
    "pino-pretty": "~13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.0",
    "@types/supertest": "~7.2.0",
    "jest": "^29.7.0",
    "supertest": "~7.2.2",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/unit/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
