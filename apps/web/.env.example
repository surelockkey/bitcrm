# Base URL for the BitCRM API gateway (nginx locally / ALB in prod).
# All requests go to `${NEXT_PUBLIC_API_BASE_URL}/{users,crm,deals,inventory}/...`.
# Public docs live at https://api.bitcrm.tech-slk.com/api/docs
NEXT_PUBLIC_API_BASE_URL=https://api.bitcrm.tech-slk.com/api

# Browser key for the dispatch map: Maps JavaScript API + Places API.
# Visible in the client bundle — restrict it by HTTP referrer in Google Cloud Console.
# (Server-side geocoding uses a separate, IP-restricted GOOGLE_MAPS_API_KEY on the backend.)
# Without it, /dispatch renders an explanation instead of a map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Map ID from Google Cloud Console -> Map management. Must be JavaScript + **Vector**:
# job pins use AdvancedMarker, which silently draws nothing without a vector Map ID.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
